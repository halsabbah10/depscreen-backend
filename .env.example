# DepScreen Backend Configuration
# Copy this file to .env and fill in your values

# LLM API — Google AI Studio (Hybrid Tier Strategy)
# Pro: adversarial detection, explanation generation (reasoning-heavy)
# Flash: chat, evidence validation, confidence calibration (balanced)
# Lite: auto-title, lightweight utilities (cheapest)
LLM_API_KEY=your-google-ai-studio-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3-flash-preview
LLM_MODEL_PRO=gemini-3.1-pro-preview
LLM_MODEL_FLASH=gemini-3-flash-preview
LLM_MODEL_LITE=gemini-3.1-flash-lite-preview

# Database — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# SQLite is NOT supported — pgvector extension is required. For local dev,
# run Postgres with pgvector (e.g. docker run pgvector/pgvector:pg16) and set:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/depscreen

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production

# RAG

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Redis (Upstash free tier — 10K commands/day)
# If empty, rate limiting uses in-memory storage (fine for single container)
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# X/Twitter integration (twikit — cookie-based auth)
# Required for social media screening via X. Create a dedicated X account.
# If unset, the X analysis endpoint returns 503 (Reddit still works).
X_USERNAME=your-x-username
X_EMAIL=your-x-email@example.com
X_PASSWORD=your-x-password

# Environment
ENVIRONMENT=development
