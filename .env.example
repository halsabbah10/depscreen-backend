# DepScreen Backend Configuration
# Copy this file to .env and fill in your values

# LLM API — Google AI Studio (Gemini 2.5 Flash)
LLM_API_KEY=your-google-ai-studio-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash

# Database — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Local SQLite fallback (uncomment for offline development)
# DATABASE_URL=sqlite:///./app.db

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production

# RAG

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Environment
ENVIRONMENT=development
